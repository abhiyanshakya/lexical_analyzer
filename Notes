test.c
int main {
    int x;
    int y;
    char c;
    x = 5;
    y = 0;
    c = 3;

    if x {
        while y {
            y = y + 1;
        }
        for i {
            _counter = i;
        }
    } else {
        do {
            x = x + 1;
        } while x;
    }

    return x;
}
